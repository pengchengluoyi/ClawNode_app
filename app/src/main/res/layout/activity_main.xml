<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="具身智能节点 · Headless Agent Node"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:text="版本 …" />

        <!-- 受限设置提示（Android 13+ sideload 必看） -->
        <TextView
            android:id="@+id/tvRestrictedHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#33FF5252"
            android:padding="12dp"
            android:text="⚠️ 检测到「受限设置」未解除：无障碍无法开启。请先点下方按钮，在应用详情 ⋮ 菜单中允许受限设置。"
            android:textColor="#B71C1C"
            android:textSize="13sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnRestricted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="① 解除受限设置（必做）"
            android:visibility="gone" />

        <!-- ============ 配置区 ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="WebSocket URL"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etWsUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="ws://auto（需先配对网关）"
            android:inputType="textUri"
            android:maxLines="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="留空或 ws://auto：需先在「发现网关并配对」中选择网关"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnDiscover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="发现网关并配对" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Auth Token"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAuthToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="节点鉴权密钥"
            android:inputType="textPassword"
            android:maxLines="1" />

        <Button
            android:id="@+id/btnSaveConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="保存配置" />

        <!-- ============ 权限就绪区 ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="权限就绪状态"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAccessibilityState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="15sp"
            android:text="● 无障碍服务：检测中…" />

        <TextView
            android:id="@+id/tvCaptureState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="15sp"
            android:text="● 屏幕捕获：检测中…" />

        <TextView
            android:id="@+id/tvBatteryState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="15sp"
            android:text="● 电池优化：检测中…" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="② 开启无障碍服务" />

        <!-- ============ 连接状态区 ============ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="网关连接状态"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvConnState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="● 未连接" />

        <!-- ============ 工具区 ============ -->
        <Button
            android:id="@+id/btnBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="关闭电池优化（后台保活）" />

        <Button
            android:id="@+id/btnScreenCapture"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="授权屏幕捕获（后台截图）" />

        <Button
            android:id="@+id/btnNotification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="通知权限设置（前台通知）" />

        <Button
            android:id="@+id/btnUploadLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="上传日志到网关" />

        <Button
            android:id="@+id/btnShareLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="分享日志（离线备用）" />

        <Button
            android:id="@+id/btnInstallPerm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="允许自动安装更新（一次性）" />

        <Button
            android:id="@+id/btnCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="检查更新（GitHub）" />

        <Button
            android:id="@+id/btnWake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="测试唤醒屏幕" />

    </LinearLayout>
</ScrollView>
