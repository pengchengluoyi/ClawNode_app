<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!--
      悬浮窗权限：Android 10+ / HyperOS 对“后台启动 Activity”(BAL) 的核心豁免开关。
      未授予时，后台 service 调 startActivity（含跳板 Activity）会被系统静默丢弃，
      前台始终回落到 com.miui.home —— 这正是 OPEN_APP / 打开设置页失败的根因。
      授予后即可从后台拉起目标应用。需用户在“显示在其他应用上层/悬浮窗”里手动开启。
    -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- MediaProjection 推流/后台截图前台服务类型（Android 14 强制要求） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <!-- 开机自启：手机重启后无需手动打开 App，节点自动上线 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Shizuku：以 shell 权限执行命令（免 root） -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23" />

    <!-- Android 11+ 包可见性：允许查询其他 App 的 Launcher Intent -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".ClawNodeApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClawNode"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">
        <!--
          usesCleartextTraffic：允许 ws://(明文) 连接局域网测试网关。
          Android 9+ 默认禁止明文，否则 OkHttp 直接 onFailure：
            "CLEARTEXT communication ... not permitted by network security policy"
          ⚠️ 生产前应收紧：移除此属性，改用 res/xml/network_security_config.xml
             仅对内网调试网段放行明文，对外一律走 wss://。
        -->

        <!-- 节点控制台入口（仅用于权限引导与连接配置） -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 透明唤醒 Activity：用于 WAKE_UP 指令点亮并解锁屏幕 -->
        <activity
            android:name=".system.WakeUpActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Transparent" />

        <!-- 前台跳板：MIUI 等禁止后台 startActivity 时由此 Activity 代为启动 -->
        <activity
            android:name=".system.LaunchTrampolineActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:theme="@style/Theme.Transparent" />

        <!-- 申请 MediaProjection 授权的透明 Activity -->
        <activity
            android:name=".system.MediaProjectionRequestActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Transparent" />

        <!-- 无障碍服务：常驻核心，承载 WsManager 与指令分发 -->
        <service
            android:name=".action.ActionExecutorService"
            android:exported="false"
            android:label="@string/accessibility_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- 节点常驻前台服务：WebSocket 保活 -->
        <service
            android:name=".service.NodeForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- 推流前台服务：承载 MediaProjection / VirtualDisplay -->
        <service
            android:name=".vision.StreamForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 单帧后台截图前台服务 -->
        <service
            android:name=".vision.ScreenshotForegroundService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <receiver
            android:name=".update.InstallResultReceiver"
            android:exported="false" />

        <receiver
            android:name=".update.UpdateReceiver"
            android:exported="true">
            <intent-filter>
                <!-- After app update/replace, auto-start services so ClawNode comes online without manual launch -->
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
            <intent-filter>
                <!-- 开机自启：设备重启后自动拉起节点服务 -->
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".ws.ConnectionWatchdogReceiver"
            android:exported="false" />

        <!-- 每日定时自动更新（凌晨 3 点）触发器 -->
        <receiver
            android:name=".update.UpdateAlarmReceiver"
            android:exported="false" />

        <!-- ClawNode 自研输入法：无 FLAG_SECURE，规避小米键盘截屏黑屏；支持远程 commitText -->
        <service
            android:name=".ime.ClawImeService"
            android:exported="true"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/ime_config" />
        </service>

        <!-- Shizuku Provider（rikka api 要求） -->
        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:multiprocess="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

    </application>

</manifest>
